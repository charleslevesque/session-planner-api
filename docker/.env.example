# Ports
API_PORT=5290
API_INTERNAL_PORT=5290
FRONTEND_PORT=5173

# Backend
ASPNETCORE_ENVIRONMENT=Development
JWT_KEY=change-me-super-secret-key-min-32-chars

# SQLite
# Container path used by the API runtime
SQLITE_PATH=/app/data/SessionPlanner.db
# Host directory used only by the dev compose file
SQLITE_DEV_HOST_DIR=../src/SessionPlanner.Api
